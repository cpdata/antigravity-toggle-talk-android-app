<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main Content Relative Layout -->
    <RelativeLayout
        android:id="@+id/main_content_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient"
        android:padding="10dp">

        <!-- Top header with Hamburger, App name and Status -->
        <RelativeLayout
            android:id="@+id/header_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <!-- Hamburger Menu Button -->
            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu"
                android:scaleType="centerInside"
                android:contentDescription="Open directory menu" />

            <!-- Title and Status centered -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_centerInParent="true">

                <TextView
                    android:id="@+id/tv_active_dir_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active: Home"
                    android:textColor="#00F2FE"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tv_active_session_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#80E6E6FA"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:maxWidth="160dp" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IDLE"
                    android:textColor="#8A8A8F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <!-- Right Drawer Menu Button -->
            <ImageButton
                android:id="@+id/btn_right_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_recent_history"
                android:scaleType="centerInside"
                android:tint="#E6E6FA"
                android:contentDescription="Open sessions menu" />
        </RelativeLayout>

        <!-- Glassmorphic Text Transcript Log Card -->
        <LinearLayout
            android:id="@+id/card_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/header_layout"
            android:layout_above="@+id/settings_layout"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:padding="8dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <ScrollView
                    android:id="@+id/scroll_log"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true">

                    <LinearLayout
                        android:id="@+id/layout_chat_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="2dp" />
                </ScrollView>

                <!-- Scroll to Bottom Button -->
                <ImageButton
                    android:id="@+id/btn_scroll_bottom"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:background="@drawable/card_glass"
                    android:src="@android:drawable/ic_menu_revert"
                    android:rotation="270"
                    android:tint="#00F2FE"
                    android:visibility="gone"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:elevation="4dp"
                    android:contentDescription="Scroll to bottom" />
            </FrameLayout>

            <!-- Thinking spinner & Terminate button container (DIRECT CHILD) -->
            <LinearLayout
                android:id="@+id/layout_thinking_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/card_glass"
                android:padding="6dp"
                android:elevation="10dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <ProgressBar
                    android:id="@+id/pb_thinking"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:indeterminate="true"
                    android:indeterminateTintMode="src_atop"
                    android:indeterminateTint="#00F2FE" />

                <!-- Red X Terminate Button -->
                <ImageButton
                    android:id="@+id/btn_terminate"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/card_glass"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#FF3B30"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="Terminate session execution"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Prompt Queue Container Layout (DIRECT CHILD) -->
            <LinearLayout
                android:id="@+id/layout_queue_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:visibility="gone"
                android:background="@drawable/card_glass"
                android:elevation="4dp">

                <!-- Collapsed Layout -->
                <LinearLayout
                    android:id="@+id/layout_queue_collapsed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tv_queue_badge"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_badge" />
                    <TextView
                        android:id="@+id/tv_queue_collapsed_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:textColor="#E6E6FA"
                        android:textSize="10sp"
                        android:ellipsize="end"
                        android:singleLine="true" />
                </LinearLayout>

                <!-- Expanded Scrollable Layout -->
                <ScrollView
                    android:id="@+id/scroll_queue_expanded"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone">
                    <LinearLayout
                        android:id="@+id/layout_queue_expanded_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom Settings (Continue session & Setup info) -->
        <LinearLayout
            android:id="@+id/settings_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="4dp">

            <!-- Top Controls Row: New Chat + Search + Mock Mode -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="4dp">

                <!-- New Chat Button -->
                <TextView
                    android:id="@+id/btn_new_chat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦ New"
                    android:textColor="#00F2FE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/card_glass"
                    android:padding="6dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Start a new chat session" />

                <!-- Search Button -->
                <ImageButton
                    android:id="@+id/btn_search"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/card_glass"
                    android:src="@android:drawable/ic_menu_search"
                    android:tint="#00F2FE"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Search conversation" />

                <!-- Artifacts Button (Icon Only) -->
                <ImageButton
                    android:id="@+id/btn_artifacts"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/card_glass"
                    android:src="@drawable/ic_folder"
                    android:tint="#00F2FE"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Show agent artifacts" />

                <!-- Expand All Button -->
                <TextView
                    android:id="@+id/btn_expand_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶ Expand"
                    android:textColor="#00F2FE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/card_glass"
                    android:padding="6dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Expand all thoughts and tool calls" />

                <!-- Settings Button -->
                <TextView
                    android:id="@+id/btn_settings"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="⚙"
                    android:textColor="#00F2FE"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/card_glass"
                    android:gravity="center"
                    android:padding="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Open settings" />
            </LinearLayout>

            <!-- Input Bar Layout -->
            <LinearLayout
                android:id="@+id/input_bar_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="6dp">

                <!-- Sleek glassmorphic text input box container -->
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/card_glass"
                    android:padding="2dp"
                    android:layout_marginEnd="5dp">

                    <!-- '+' Add Options Button -->
                    <ImageButton
                        android:id="@+id/btn_add_options"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_input_add"
                        android:tint="#00F2FE"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="Add files, camera or quick prompts"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Mic Action Button Container -->
                    <FrameLayout
                        android:id="@+id/mic_inside_container"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true">

                        <!-- Concentric Ring 3 (Outer Ring for Pulsing) -->
                        <View
                            android:id="@+id/ring_outer"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_mic_btn"
                            android:alpha="0" />

                        <!-- Concentric Ring 2 (Middle Ring for Pulsing) -->
                        <View
                            android:id="@+id/ring_middle"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_mic_btn"
                            android:alpha="0" />

                        <!-- Concentric Ring 1 (Inner Ring/Halo) -->
                        <View
                            android:id="@+id/ring_inner"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_mic_btn"
                            android:alpha="0" />

                        <!-- Main Mic Action Button -->
                        <ImageButton
                            android:id="@+id/btn_mic"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_mic_btn"
                            android:src="@drawable/ic_mic"
                            android:padding="5dp"
                            android:scaleType="fitCenter"
                            android:tint="#120E2E"
                            android:contentDescription="Toggle voice record" />
                    </FrameLayout>

                    <EditText
                        android:id="@+id/et_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/btn_add_options"
                        android:layout_toStartOf="@id/mic_inside_container"
                        android:layout_centerVertical="true"
                        android:minHeight="40dp"
                        android:hint="Type or speak..."
                        android:textColor="#FFFFFF"
                        android:textColorHint="#80FFFFFF"
                        android:background="@null"
                        android:padding="8dp"
                        android:textSize="13sp"
                        android:maxLines="4"
                        android:scrollbars="vertical"
                        android:textCursorDrawable="@drawable/cursor_color" />
                </RelativeLayout>

                <!-- Send Button -->
                <ImageButton
                    android:id="@+id/btn_send"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/card_glass"
                    android:src="@android:drawable/ic_menu_send"
                    android:tint="#00F2FE"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="Send text message"
                    android:elevation="6dp" />

                <!-- X Button for flushing (outside, or could be moved) -->
                <ImageButton
                    android:id="@+id/btn_flush"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@null"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#FF3B30"
                    android:scaleType="fitCenter"
                    android:padding="2dp"
                    android:visibility="gone"
                    android:layout_marginStart="4dp"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="Stop and flush audio queue" />

                <!-- Unresolved Queue State Actions -->
                <LinearLayout
                    android:id="@+id/layout_unresolved_actions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginStart="5dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prompt Queue?"
                        android:textColor="#FF3B30"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />
                        
                    <Button
                        android:id="@+id/btn_queue_resume"
                        android:layout_width="75dp"
                        android:layout_height="28dp"
                        android:text="Resume"
                        android:textSize="10sp"
                        android:padding="0dp"
                        android:background="@drawable/card_glass"
                        android:textColor="#4CD964" />
                        
                    <Button
                        android:id="@+id/btn_queue_delete"
                        android:layout_width="75dp"
                        android:layout_height="28dp"
                        android:text="Delete"
                        android:textSize="10sp"
                        android:padding="0dp"
                        android:background="@drawable/card_glass"
                        android:textColor="#FF3B30"
                        android:layout_marginTop="2dp" />
                        
                    <Button
                        android:id="@+id/btn_queue_combine"
                        android:layout_width="75dp"
                        android:layout_height="28dp"
                        android:text="Combine"
                        android:textSize="10sp"
                        android:padding="0dp"
                        android:background="@drawable/card_glass"
                        android:textColor="#00F2FE"
                        android:layout_marginTop="2dp" />
                        
                    <Button
                        android:id="@+id/btn_queue_add"
                        android:layout_width="75dp"
                        android:layout_height="28dp"
                        android:text="Add"
                        android:textSize="10sp"
                        android:padding="0dp"
                        android:background="@drawable/card_glass"
                        android:textColor="#E6E6FA"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </RelativeLayout>
</FrameLayout>
