<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/content_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- View Flipper for switching between views -->
    <ViewFlipper
        android:id="@+id/view_flipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layout_shared_footer">
        
        <!-- Index 0: Menu View -->
        <include layout="@layout/layout_menu" />
        
        <!-- Index 1: Chat View -->
        <include layout="@layout/layout_chat" />
        
        <!-- Index 2: Commands View -->
        <include layout="@layout/layout_commands" />
    </ViewFlipper>

    <!-- Shared Footer -->
    <LinearLayout
        android:id="@+id/layout_shared_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="8dp"
        android:background="#0B0518"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_footer_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menu"
            android:textColor="#FFFFFF"
            android:background="@drawable/card_glass"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginBottom="4dp" />
    </LinearLayout>

    <!-- Navigation Drawer (Shared) -->
    <include layout="@layout/layout_bottom_navigation_drawer" />

    <!-- Slide-out Left Drawer Overlay Container (Shared) -->
    <FrameLayout
        android:id="@+id/drawer_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <View
            android:id="@+id/drawer_dim_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#A6000000"
            android:alpha="0" />
        <LinearLayout
            android:id="@+id/drawer_content"
            android:layout_width="260dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:orientation="vertical"
            android:background="#FA0B0518"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="16dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp">
                <TextView
                    android:id="@+id/tv_drawer_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INITIAL DIRECTORY"
                    android:textColor="#E6E6FA"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
                <ImageButton
                    android:id="@+id/btn_refresh_dirs"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/stat_notify_sync"
                    android:tint="#E6E6FA"
                    android:contentDescription="Refresh directories list" />
            </RelativeLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select the directory context where the Antigravity CLI will be run:"
                android:textColor="#A0E6E6FA"
                android:textSize="11sp"
                android:layout_marginBottom="12dp"
                android:lineSpacingMultiplier="1.2" />
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <ListView
                    android:id="@+id/lv_directories"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:divider="@null"
                    android:dividerHeight="0dp" />
                <ProgressBar
                    android:id="@+id/pb_drawer_loading"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="#00F2FE" />
                <TextView
                    android:id="@+id/tv_empty_dirs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="No directories found in home"
                    android:textColor="#60FFFFFF"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </FrameLayout>
            <TextView
                android:id="@+id/tv_active_dir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"
                android:text="Active: Home"
                android:textColor="#E6E6FA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </FrameLayout>

    <!-- Slide-out Right Drawer Overlay Container (Shared) -->
    <FrameLayout
        android:id="@+id/right_drawer_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <View
            android:id="@+id/right_drawer_dim_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#A6000000"
            android:alpha="0" />
        <LinearLayout
            android:id="@+id/right_drawer_content"
            android:layout_width="260dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:orientation="vertical"
            android:background="#FA0B0518"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="16dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp">
                <TextView
                    android:id="@+id/tv_right_drawer_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANTIGRAVITY SESSIONS"
                    android:textColor="#E6E6FA"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
                <ImageButton
                    android:id="@+id/btn_refresh_sessions"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/stat_notify_sync"
                    android:tint="#E6E6FA"
                    android:contentDescription="Refresh sessions list" />
            </RelativeLayout>
            <TextView
                android:id="@+id/btn_new_chat_drawer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✦  New Chat"
                android:textColor="#00F2FE"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:paddingStart="12dp"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="4dp"
                android:background="@drawable/card_glass"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Start a new chat session" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#20FFFFFF"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="2dp" />
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <ListView
                    android:id="@+id/lv_sessions"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:divider="@null"
                    android:dividerHeight="0dp" />
                <ProgressBar
                    android:id="@+id/pb_right_drawer_loading"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="#00F2FE" />
                <TextView
                    android:id="@+id/tv_empty_sessions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="No sessions found"
                    android:textColor="#60FFFFFF"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </FrameLayout>
            <TextView
                android:id="@+id/tv_active_session"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"
                android:text="Active: None"
                android:textColor="#E6E6FA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </FrameLayout>

    <!-- Settings Popup Overlay Container (Shared) -->
    <FrameLayout
        android:id="@+id/settings_popup_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <View
            android:id="@+id/settings_popup_dim_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#A6000000" />
        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="#FA0B0518"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="24dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SETTINGS"
                    android:textColor="#E6E6FA"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
                <ImageButton
                    android:id="@+id/btn_settings_close"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#E6E6FA"
                    android:contentDescription="Close settings" />
            </RelativeLayout>
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:fillViewport="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <CheckBox
                        android:id="@+id/cb_mock_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mock Mode"
                        android:textColor="#E6E6FA"
                        android:textSize="14sp"
                        android:buttonTint="#9D50BB"
                        android:paddingStart="8dp"
                        android:layout_marginBottom="12dp"
                        android:checked="false" />
                    <CheckBox
                        android:id="@+id/cb_wake_lock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="WakeLock"
                        android:textColor="#E6E6FA"
                        android:textSize="14sp"
                        android:buttonTint="#9D50BB"
                        android:paddingStart="8dp"
                        android:layout_marginBottom="12dp"
                        android:checked="false" />
                    <CheckBox
                        android:id="@+id/cb_collapse_tools"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Collapse Tool Messages"
                        android:textColor="#E6E6FA"
                        android:textSize="14sp"
                        android:buttonTint="#9D50BB"
                        android:paddingStart="8dp"
                        android:layout_marginBottom="12dp"
                        android:checked="false" />
                    <CheckBox
                        android:id="@+id/cb_collapse_thoughts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Collapse Thoughts"
                        android:textColor="#E6E6FA"
                        android:textSize="14sp"
                        android:buttonTint="#9D50BB"
                        android:paddingStart="8dp"
                        android:layout_marginBottom="12dp"
                        android:checked="false" />
                    <TextView
                        android:id="@+id/btn_clear_session_cache"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Clear Session History Cache"
                        android:textColor="#FF416C"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:padding="12dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/card_glass"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Clear session history cache" />
                    <TextView
                        android:id="@+id/btn_kill_all"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="KILL ALL SESSIONS"
                        android:textColor="#FF416C"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:padding="12dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/card_glass"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Kill all sessions and clear TTS queue" />
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- Artifacts Popup (Shared) -->
    <FrameLayout
        android:id="@+id/artifacts_popup_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <View
            android:id="@+id/artifacts_popup_dim_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#A6000000" />
        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="400dp"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="#FA0B0518"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="24dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ARTIFACTS"
                    android:textColor="#E6E6FA"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
                <ImageButton
                    android:id="@+id/btn_artifacts_close"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#E6E6FA"
                    android:contentDescription="Close artifacts" />
            </RelativeLayout>
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">
                <LinearLayout
                    android:id="@+id/layout_artifacts_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- Prompt Edit Popup (Shared) -->
    <FrameLayout
        android:id="@+id/prompt_edit_popup_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <View
            android:id="@+id/prompt_edit_popup_dim_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="#F00B0518"
            android:padding="8dp"
            android:layout_margin="8dp"
            android:elevation="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Queued Prompt"
                android:textColor="#E6E6FA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />
            <EditText
                android:id="@+id/et_edit_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:maxLines="6"
                android:scrollbars="vertical"
                android:inputType="textMultiLine"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/card_glass"
                android:padding="8dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="6dp">
                <Button android:id="@+id/btn_edit_delete" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delete" android:textColor="#FF3B30" style="?android:attr/buttonBarButtonStyle" />
                <Button android:id="@+id/btn_edit_cancel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cancel" android:textColor="#8A8A8F" style="?android:attr/buttonBarButtonStyle" />
                <Button android:id="@+id/btn_edit_update" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Update" android:textColor="#00F2FE" style="?android:attr/buttonBarButtonStyle" />
                <Button android:id="@+id/btn_edit_send" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Send" android:textColor="#4CD964" style="?android:attr/buttonBarButtonStyle" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Search Popup (Shared) -->
    <FrameLayout
        android:id="@+id/search_popup_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <View
            android:id="@+id/search_popup_dim_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="#F00B0518"
            android:padding="8dp"
            android:layout_margin="8dp"
            android:elevation="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Search Conversation"
                    android:textColor="#E6E6FA"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <ImageButton
                    android:id="@+id/btn_search_close"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#E6E6FA"
                    android:scaleType="fitCenter" />
            </LinearLayout>
            <EditText
                android:id="@+id/et_search_popup"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:hint="Search..."
                android:textColor="#FFFFFF"
                android:textColorHint="#80FFFFFF"
                android:background="@drawable/card_glass"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textSize="12sp"
                android:singleLine="true"
                android:imeOptions="actionSearch" />
            <ListView
                android:id="@+id/lv_search_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:divider="#20FFFFFF"
                android:dividerHeight="1dp"
                android:maxHeight="180dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Add Options Drawer (Shared) -->
    <FrameLayout
        android:id="@+id/add_options_drawer_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <View
            android:id="@+id/add_options_dim_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />
        <LinearLayout
            android:id="@+id/add_options_drawer_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="#F00B0518"
            android:padding="16dp"
            android:layout_margin="8dp"
            android:elevation="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add to conversation"
                android:textColor="#E6E6FA"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />
            <LinearLayout
                android:id="@+id/option_files"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_folder"
                    android:tint="#00F2FE" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Files"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginStart="16dp" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/option_camera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:tint="#00F2FE" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Camera"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginStart="16dp" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/option_quick_prompts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_menu"
                    android:tint="#00F2FE" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Prompts"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginStart="16dp" />
            </LinearLayout>
            <Button
                android:id="@+id/btn_add_options_close"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textColor="#8A8A8F"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Quick Prompts Popup (Shared) -->
    <FrameLayout
        android:id="@+id/quick_prompts_popup_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <View
            android:id="@+id/quick_prompts_popup_dim_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="#F00B0518"
            android:padding="8dp"
            android:layout_margin="8dp"
            android:elevation="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Prompts"
                android:textColor="#E6E6FA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <EditText
                    android:id="@+id/et_new_quick_prompt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="42dp"
                    android:hint="New prompt..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#80FFFFFF"
                    android:background="@drawable/card_glass"
                    android:padding="8dp"
                    android:textSize="13sp" />
                <Button
                    android:id="@+id/btn_add_quick_prompt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add"
                    android:textColor="#00F2FE"
                    style="?android:attr/buttonBarButtonStyle" />
            </LinearLayout>
            <ListView
                android:id="@+id/lv_quick_prompts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="#20FFFFFF"
                android:dividerHeight="1dp" />
            <Button
                android:id="@+id/btn_quick_prompts_close"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Close"
                android:textColor="#8A8A8F"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>
