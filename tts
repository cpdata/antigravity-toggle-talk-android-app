#!/data/data/com.termux/files/usr/bin/bash
# =============================================================================
# tts — Kokoro TTS CLI wrapper (with streaming support)
# Usage:  tts [-a|--await] 'text to speak' [voice] [speed]
# Voices: af_heart (default), af_bella, af_sarah, am_adam, am_michael,
#         bf_emma, bm_george
# Speed:  0.5 (slow) to 2.0 (fast), default 1.0
# Examples:
#   tts 'Hello world'
#   tts 'Hello world' af_bella
#   tts -a 'Hello world' am_adam 1.2
# =============================================================================

set -e

# Parse arguments
AWAIT=false
ARGS=()
for arg in "$@"; do
    if [ "$arg" = "-a" ] || [ "$arg" = "--await" ]; then
        AWAIT=true
    else
        ARGS+=("$arg")
    fi
done

if [ ${#ARGS[@]} -lt 1 ]; then
    echo "Usage: tts [-a|--await] 'text to speak' [voice] [speed]"
    echo "Voices: af_heart af_bella af_sarah am_adam am_michael bf_emma bm_george"
    exit 1
fi

TEXT="${ARGS[0]}"
VOICE="${ARGS[1]:-af_heart}"
SPEED="${ARGS[2]:-1.0}"

OUTDIR="/data/data/com.termux/files/home/.kokoro-tts-output"
mkdir -p "$OUTDIR"
rm -f "$OUTDIR"/*.wav

if [ "$AWAIT" = "true" ]; then
    OUTFILE="$OUTDIR/.kokoro_tts_output.wav"

    # Run Kokoro inside Ubuntu proot in await mode
    if proot-distro login ubuntu -- \
        /opt/kokoro-tts/venv/bin/python3 /opt/kokoro-tts/tts_engine.py \
        "$TEXT" "$VOICE" "$SPEED" "$OUTFILE" 2>/dev/null; then

        if [ -f "$OUTFILE" ]; then
            # Play using termux-media-player (Termux:API)
            termux-media-player play "$OUTFILE" >/dev/null 2>&1
            # Wait for playback to finish
            WORDS=$(echo "$TEXT" | wc -w)
            WAIT=$(python3 -c "import math; print(max(3, math.ceil($WORDS * 0.5 / $SPEED)))")
            sleep "$WAIT"
            # Clean up output file
            rm -f "$OUTFILE"
        else
            echo "TTS Error: Output file not created." >&2
            exit 1
        fi
    else
        echo "TTS Error: Synthesis failed inside proot." >&2
        exit 1
    fi
else
    # Run Kokoro inside Ubuntu proot in streaming mode
    # Read stdout line-by-line to play and clean up chunk files natively
    OUTFILE_DUMMY="$OUTDIR/dummy.wav"

    proot-distro login ubuntu -- \
        /opt/kokoro-tts/venv/bin/python3 /opt/kokoro-tts/tts_engine.py \
        "$TEXT" "$VOICE" "$SPEED" "$OUTFILE_DUMMY" --stream 2>/dev/null | \
    while read -r line; do
        if [[ "$line" =~ ^PLAY:\ ([^\ ]+)\ ([0-9.]+) ]]; then
            chunk_file="${BASH_REMATCH[1]}"
            duration="${BASH_REMATCH[2]}"

            # Start playback natively on host
            termux-media-player play "$chunk_file" >/dev/null 2>&1

            # Sleep for the majority of chunk duration
            WAIT=$(python3 -c "print(max(0.0, $duration - 0.2))")
            sleep "$WAIT"

            # Poll status until playback completes
            while true; do
                if ! termux-media-player info 2>/dev/null | grep -q "Status: Playing"; then
                    break
                fi
                sleep 0.05
            done

            # Delete chunk immediately
            rm -f "$chunk_file"
        fi
    done
fi
